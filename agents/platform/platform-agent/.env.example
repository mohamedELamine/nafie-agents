# ============================================================
# Platform Agent — Environment Variables Template
# نسخ هذا الملف إلى .env وملء القيم الحقيقية
# ⚠️  لا ترفع .env إلى git أبداً
# ============================================================

# --- Lemon Squeezy ---
LS_API_KEY=
LS_STORE_ID=
LS_WEBHOOK_SECRET=
# ls_product_id للباقة VIP (يُنشأ مرة واحدة يدوياً)
LS_VIP_PRODUCT_ID=

# --- WordPress ---
# يجب أن يبدأ بـ https:// — يُرفض http في الكود
WP_SITE_URL=https://nafic.com
# مستخدم WordPress بصلاحيات Editor (لا administrator)
WP_API_USER=platform_agent
# Application Password من WordPress (Settings → Application Passwords)
WP_API_PASSWORD=

# --- Resend (Email) ---
RESEND_API_KEY=
# اسم + بريد المرسل (يظهر للمشترين)
STORE_EMAIL_FROM=نافع <hello@nafic.com>
STORE_URL=https://nafic.com

# --- Database ---
DATABASE_URL=postgresql://platform_agent:password@localhost:5432/platform_db

# --- Redis ---
REDIS_URL=redis://localhost:6379
# Stream names (يتطابق مع باقي الوكلاء)
REDIS_STREAM_THEME_EVENTS=theme-events
REDIS_STREAM_PRODUCT_EVENTS=product-events
REDIS_STREAM_ASSET_EVENTS=asset-events
REDIS_STREAM_SALES_EVENTS=sales-events
# اسم Consumer Group
REDIS_CONSUMER_GROUP=platform-agent

# --- Claude API (للـ page_writer و page_renderer) ---
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-opus-4-6

# --- Business Rules ---
# بريد صاحب المشروع — يستقبل طلبات المراجعة والتنبيهات
OWNER_EMAIL=
# مهلة الموافقة البشرية (ساعات)
HUMAN_REVIEW_TIMEOUT_HOURS=48
# مهلة انتظار الـ assets الأولى (ساعات)
ASSET_INITIAL_WAIT_HOURS=4
# مهلة التمديد (مرة واحدة فقط)
ASSET_EXTENSION_HOURS=4
# أقصى دورات مراجعة قبل LAUNCH_HOLD
MAX_REVISION_CYCLES=3

# --- Logging ---
LOG_LEVEL=INFO
