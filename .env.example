# ══════════════════════════════════════════════════════
# منظومة قوالب WordPress العربية — متغيرات البيئة
# انسخ هذا الملف إلى .env وأدخل قيمك
# ══════════════════════════════════════════════════════

# ── نماذج الذكاء الاصطناعي ────────────────────────────

# Claude (Anthropic) — مطلوب لجميع الوكلاء
ANTHROPIC_API_KEY=sk-ant-...

# LangSmith — للمراقبة والتتبع
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=ar-themes-ecosystem

# Gemini — لوكيل البناء (Frontend generation)
GEMINI_API_KEY=AIza...

# GLM — لوكيل البناء (Backend/PHP generation)
GLM_API_KEY=...

# ── نماذج التوليد البصري ──────────────────────────────

# Flux 2 Pro — الصور الواقعية
FLUX_API_KEY=...

# Ideogram V3 — الصور ذات النص العربي
IDEOGRAM_API_KEY=...

# Kling AI 2.1 — الفيديو الترويجي
KLING_API_KEY=...
KLING_ACCESS_KEY=...

# Pika Labs — الفيديو القصير
PIKA_API_KEY=...

# ── WooCommerce / WordPress ────────────────────────────

WOO_BASE_URL=https://your-store.com
WOO_CONSUMER_KEY=ck_...
WOO_CONSUMER_SECRET=cs_...
WP_USERNAME=admin
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ── قاعدة البيانات ─────────────────────────────────────

POSTGRES_DB=ar_themes
POSTGRES_USER=ar_themes_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis ──────────────────────────────────────────────

REDIS_URL=redis://localhost:6379
# إن كان Redis يحتاج كلمة مرور:
# REDIS_PASSWORD=...

# ── التسويق ────────────────────────────────────────────

# MailerLite — البريد الإلكتروني
MAILERLITE_API_KEY=...

# Twitter/X API v2
TWITTER_BEARER_TOKEN=AAA...
TWITTER_API_KEY=...
TWITTER_API_SECRET=...
TWITTER_ACCESS_TOKEN=...
TWITTER_ACCESS_TOKEN_SECRET=...

# Meta (Facebook + Instagram)
META_ACCESS_TOKEN=...
META_PAGE_ID=...
META_IG_ACCOUNT_ID=...

# Telegram
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...       # للمالك (إشعارات)
TELEGRAM_CHANNEL_ID=...    # القناة العامة (تسويق)

# ── Google Analytics 4 ─────────────────────────────────

GA4_PROPERTY_ID=...
# مسار ملف Service Account JSON (أو محتواه كـ base64)
GA4_CREDENTIALS=/app/credentials/ga4-service-account.json

# ── الإعدادات العامة ───────────────────────────────────

LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
ENVIRONMENT=production  # development | staging | production

# المنطقة الزمنية للجدولة
TIMEZONE=Asia/Riyadh    # UTC+3

# ── حدود الأمان ────────────────────────────────────────

# الحد الأقصى لحجم الجمهور التسويقي بدون موافقة
MAX_AUDIENCE_WITHOUT_APPROVAL=1000

# الحد الأقصى لتغيير السعر بدون موافقة (نسبة مئوية)
MAX_PRICE_CHANGE_PCT=20

# مهلة القرار البشري (بالساعات)
HUMAN_DECISION_TIMEOUT_HOURS=4
