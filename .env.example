# ================= Database =================

# رابط قاعدة البيانات الرئيسي المشترك بين الوكلاء والخدمات. [scopes: all]
DATABASE_URL=postgresql://app_user:change_me@postgres:5432/ar_themes

# رابط قاعدة البيانات الخاص باختبارات التكامل فقط. [scopes: tests]
TEST_DATABASE_URL=postgresql://test_user:change_me@localhost:5432/ar_themes_test

# رابط قاعدة البيانات المخصّص لوكيل التسويق عند الحاجة إلى فصل الاتصال. [scopes: marketing]
MARKETING_DATABASE_URL=postgresql://marketing_user:change_me@postgres:5432/ar_themes

# رابط قاعدة البيانات المخصّص لوكيل الدعم عند الحاجة إلى فصل الاتصال. [scopes: support]
SUPPORT_DATABASE_URL=postgresql://support_user:change_me@postgres:5432/ar_themes

# رابط قاعدة البيانات المخصّص لوكيل الإنتاج البصري عند الحاجة إلى فصل الاتصال. [scopes: visual]
VISUAL_DATABASE_URL=postgresql://visual_user:change_me@postgres:5432/ar_themes

# اسم مضيف PostgreSQL الذي تتصل به الخدمات الداخلية. [scopes: all]
POSTGRES_HOST=postgres

# منفذ PostgreSQL الداخلي المستخدم بين الحاويات والخدمات. [scopes: all]
POSTGRES_PORT=5432

# اسم قاعدة البيانات الأساسية للمنظومة. [scopes: all]
POSTGRES_DB=ar_themes

# اسم مستخدم PostgreSQL الافتراضي للتشغيل المحلي والحاويات. [scopes: all]
POSTGRES_USER=app_user

# كلمة مرور PostgreSQL الافتراضية ويجب استبدالها في البيئات الحقيقية. [scopes: all]
POSTGRES_PASSWORD=change_me

# ================= Redis =================

# رابط Redis الموحد لحافلة الأحداث والـ streams. [scopes: all]
REDIS_URL=redis://redis:6379/0

# اسم مضيف Redis للاتصالات التي تستخدم host/port بدل URL. [scopes: all]
REDIS_HOST=redis

# منفذ Redis للاتصالات الداخلية. [scopes: all]
REDIS_PORT=6379

# اسم consumer group الافتراضي لبعض المستمعات القديمة. [scopes: all]
REDIS_CONSUMER_GROUP=ecosystem-group

# اسم stream الخاص بأحداث إطلاق المنتجات. [scopes: all]
REDIS_STREAM_PRODUCT_EVENTS=product-events

# اسم stream الخاص بأحداث القوالب العامة. [scopes: all]
REDIS_STREAM_THEME_EVENTS=theme-events

# اسم stream الخاص بأحداث الأصول البصرية. [scopes: all]
REDIS_STREAM_ASSET_EVENTS=asset-events

# اسم stream الخاص بأحداث المبيعات والتحليلات. [scopes: analytics]
REDIS_STREAM_SALES_EVENTS=sales-events

# ================= Email =================

# مفتاح Resend لإرسال التنبيهات والبريد التشغيلي. [scopes: supervisor,platform,support,visual]
RESEND_API_KEY=replace-me

# عنوان البريد المستخدَم في حقل From داخل رسائل Resend. [scopes: platform,visual]
RESEND_FROM_EMAIL=no-reply@example.com

# عنوان المرسل الظاهر لرسائل المتجر والنشرة. [scopes: platform]
STORE_EMAIL_FROM=Arabic Themes <no-reply@example.com>

# بريد المالك الذي يستقبل التنبيهات والتصعيدات. [scopes: supervisor,platform,marketing,support,visual]
OWNER_EMAIL=owner@example.com

# بريد مالك الأصول البصرية للمراجعة والإشعارات. [scopes: visual]
VISUAL_OWNER_EMAIL=owner@example.com

# رابط المتجر المستخدم داخل الرسائل والمعاملات. [scopes: platform]
STORE_URL=https://example.com

# مفتاح Telegram Bot للتنبيهات الإدارية. [scopes: supervisor,marketing]
TELEGRAM_BOT_TOKEN=replace-me

# معرّف محادثة Telegram للمدير أو غرفة العمليات. [scopes: supervisor]
TELEGRAM_CHAT_ID=000000000

# معرّف قناة Telegram للنشر التسويقي. [scopes: marketing]
TELEGRAM_CHANNEL_ID=@example_channel

# مفتاح MailerLite لتوزيع الحملات البريدية. [scopes: marketing]
MAILERLITE_API_KEY=replace-me

# ================= WooCommerce =================

# رابط WooCommerce الأساسي الذي يقرأ منه وكيل التحليل المبيعات. [scopes: analytics]
WOO_BASE_URL=https://example.com/wp-json/wc/v3

# مفتاح WooCommerce العام للقراءة من واجهة المتجر. [scopes: analytics]
WOO_CONSUMER_KEY=replace-me

# السرّ المقابل لمفتاح WooCommerce. [scopes: analytics]
WOO_CONSUMER_SECRET=replace-me

# رابط موقع WordPress الذي ينشر عليه وكيل المنصة. [scopes: platform]
WP_SITE_URL=https://example.com

# اسم مستخدم WordPress الخاص بعمليات النشر البرمجية. [scopes: platform]
WP_API_USER=platform_agent

# كلمة مرور أو application password الخاصة بواجهة WordPress. [scopes: platform]
WP_API_PASSWORD=replace-me

# ================= LemonSqueezy =================

# مفتاح LemonSqueezy لإدارة المنتجات والنسخ. [scopes: platform]
LS_API_KEY=replace-me

# معرّف المتجر داخل LemonSqueezy. [scopes: platform]
LS_STORE_ID=store_123

# السرّ المستخدم للتحقق من webhooks الواردة من LemonSqueezy. [scopes: platform]
LS_WEBHOOK_SECRET=replace-me

# معرّف منتج VIP التجميعي في LemonSqueezy. [scopes: platform]
LS_VIP_PRODUCT_ID=vip_product_123

# ================= HelpScout =================

# مفتاح HelpScout الرئيسي لوكيل الدعم. [scopes: support]
HELPSCOUT_API_KEY=replace-me

# معرّف التطبيق أو التكامل داخل HelpScout. [scopes: support]
HELPSCOUT_APP_ID=app_123

# معرّف صندوق البريد المستهدف في HelpScout. [scopes: support]
HELPSCOUT_MAILBOX_ID=mailbox_123

# اسم قديم متوافق للخلف لمفتاح HelpScout. [scopes: support]
HELP_SCOUT_API_KEY=replace-me

# اسم قديم متوافق للخلف لمعرّف صندوق HelpScout. [scopes: support]
HELP_SCOUT_MAILBOX_ID=mailbox_123

# ================= Facebook =================

# رمز صفحة Facebook المستخدم للردود أو النشر المباشر. [scopes: support,marketing]
FACEBOOK_PAGE_TOKEN=replace-me

# رمز Meta العام للقنوات الاجتماعية التابعة لـ Facebook وInstagram. [scopes: marketing]
META_ACCESS_TOKEN=replace-me

# معرّف صفحة Meta أو Facebook المستخدمة للنشر. [scopes: marketing]
META_PAGE_ID=page_123

# رمز Instagram للنشر أو الجلب عبر تكامل Meta. [scopes: marketing]
INSTAGRAM_ACCESS_TOKEN=replace-me

# رمز WhatsApp Business للنشر أو الردود الآلية. [scopes: marketing]
WHATSAPP_ACCESS_TOKEN=replace-me

# معرّف رقم WhatsApp Business المستخدم للإرسال. [scopes: marketing]
WHATSAPP_PHONE_NUMBER_ID=phone_123

# ================= Qdrant =================

# رابط Qdrant الكامل عند استخدامه عبر URL مباشر. [scopes: support]
QDRANT_URL=http://qdrant:6333

# اسم مضيف Qdrant للاتصالات التي تستخدم host/port. [scopes: support]
QDRANT_HOST=qdrant

# منفذ Qdrant الخاص بخدمة البحث الدلالي. [scopes: support]
QDRANT_PORT=6333

# مزود embeddings المستخدم في وكيل الدعم. [scopes: support]
SUPPORT_EMBEDDING_PROVIDER=openai

# رابط واجهة embeddings إذا كان المزود OpenAI-compatible. [scopes: support]
SUPPORT_EMBEDDING_BASE_URL=https://api.openai.com/v1

# اسم نموذج embeddings المستخدم في الاسترجاع المعرفي. [scopes: support]
SUPPORT_EMBEDDING_MODEL=text-embedding-3-small

# حجم المتجهات المتوقع داخل مجموعة Qdrant. [scopes: support]
SUPPORT_EMBEDDING_VECTOR_SIZE=1536

# ================= General =================

# مفتاح Anthropic الأساسي للوكلاء التي تستخدم Claude مباشرة. [scopes: supervisor,content,marketing,analytics,support,visual,builder]
ANTHROPIC_API_KEY=replace-me

# الاسم القديم المتوافق للخلف لمفتاح Claude في بعض الخدمات. [scopes: platform]
CLAUDE_API_KEY=replace-me

# اسم نموذج Claude الافتراضي للوكيل الذي يحتاج تخصيصًا صريحًا. [scopes: platform]
CLAUDE_MODEL=claude-opus-4-1

# مفتاح OpenAI المطلوب لبعض embeddings أو الخدمات المتوافقة. [scopes: support]
OPENAI_API_KEY=replace-me

# مفتاح Gemini المستخدم داخل بعض أدوات البناء والتحليل. [scopes: builder]
GEMINI_API_KEY=replace-me

# مفتاح GLM المستخدم كخيار بديل للنماذج النصية. [scopes: builder]
GLM_API_KEY=replace-me

# مفتاح ZhipuAI المستخدم لبعض مهام البناء متعددة المزودات. [scopes: builder]
ZHIPUAI_API_KEY=replace-me

# مفتاح LangChain لبعض مسارات التجريب أو التتبع. [scopes: builder]
LANGCHAIN_API_KEY=replace-me

# اسم مشروع LangChain المرتبط بجلسات التتبع. [scopes: builder]
LANGCHAIN_PROJECT=arabic-themes-ecosystem

# تفعيل تتبع LangChain إذا كانت البيئة تحتاجه. [scopes: builder]
LANGCHAIN_TRACING_V2=false

# مفتاح LangSmith للتتبع المركزي للوكلاء. [scopes: supervisor,support,analytics,builder]
LANGSMITH_API_KEY=replace-me

# اسم مشروع LangSmith الموحد للتتبع. [scopes: supervisor,analytics,builder]
LANGSMITH_PROJECT=arabic-themes-ecosystem

# مفتاح CodeRabbit إن كان البناء أو المراجعات الآلية تعتمد عليه. [scopes: builder]
CODERABBIT_API_KEY=replace-me

# مفتاح Testsprite للأدوات المساندة داخل وكيل البناء. [scopes: builder]
TESTSPRITE_API_KEY=replace-me

# مفتاح Flux لتوليد الصور في وكيل الإنتاج البصري. [scopes: visual]
FLUX_API_KEY=replace-me

# مفتاح Ideogram لتوليد الصور أو النصوص البصرية. [scopes: visual]
IDEOGRAM_API_KEY=replace-me

# مفتاح Kling لتوليد الفيديو أو الحركة عند تفعيله. [scopes: visual]
KLING_API_KEY=replace-me

# مفتاح الوصول الإضافي لخدمة Kling إن كان مطلوبًا. [scopes: visual]
KLING_ACCESS_KEY=replace-me

# مفتاح Pika لمسارات الفيديو القصير أو الحركة. [scopes: visual]
PIKA_API_KEY=replace-me

# خاصية CORS المسموح بها لواجهات الـ API. [scopes: content,visual]
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# مستوى السجلات الافتراضي لكل الخدمات. [scopes: all]
LOG_LEVEL=INFO

# تفعيل وضع التصحيح في البيئات المحلية فقط. [scopes: support,supervisor,visual]
DEBUG=false

# اسم البيئة الحالية مثل development أو staging أو production. [scopes: support,supervisor,visual]
ENVIRONMENT=development

# مهلة اعتبار الوكيل مفقود النبضات قبل التصعيد الصحي. [scopes: supervisor]
HEARTBEAT_TIMEOUT_SEC=120

# الفاصل الزمني بين دورات فحص الصحة داخل المشرف. [scopes: supervisor]
HEALTH_CHECK_INTERVAL_SEC=60

# اسم المضيف الذي تستخدمه بعض الـ listeners كهوية للمستهلك. [scopes: platform]
HOSTNAME=ecosystem-local

# مسار التخزين المحلي للأصول المولدة والملفات المؤقتة. [scopes: visual]
STORAGE_PATH=/app/storage

# نسخة دستور العلامة التجارية التي يعتمدها وكيل المحتوى. [scopes: content]
BRAND_CONSTITUTION_VERSION=1.0

# نسخة منطق التخطيط المستخدمة في توليد المحتوى. [scopes: content]
PLANNER_VERSION=1.0

# نسخة منطق التحقق المستخدمة في مراجعة المحتوى. [scopes: content]
VALIDATOR_VERSION=1.0

# الحد الأدنى المقبول لدرجة تحقق المحتوى قبل النشر. [scopes: content]
MIN_VALIDATION_SCORE=0.60

# نافذة الإسناد بالأيام داخل وكيل التحليل للمبيعات والقنوات. [scopes: analytics]
ATTRIBUTION_WINDOW_DAYS=7

# مهلة الانتظار الأولى لوصول الأصول البصرية قبل التحذير. [scopes: platform]
ASSET_INITIAL_WAIT_HOURS=4

# عدد الساعات الإضافية المسموح بها قبل إلغاء انتظار الأصول. [scopes: platform]
ASSET_EXTENSION_HOURS=4

# مهلة المراجعة البشرية العامة قبل التصعيد أو الإنهاء. [scopes: platform]
HUMAN_REVIEW_TIMEOUT_HOURS=48

# الحد الأقصى لعدد دورات المراجعة أو التعديل قبل الإيقاف. [scopes: platform]
MAX_REVISION_CYCLES=3

# الحد الأعلى لتكلفة الدفعة البصرية الواحدة. [scopes: visual]
VISUAL_BUDGET_LIMIT=2.00

# معرّف خاصية GA4 التي يقرأ منها وكيل التحليل. [scopes: analytics]
GA4_PROPERTY_ID=123456789

# بيانات اعتماد GA4 بصيغة JSON أو path حسب أسلوب النشر. [scopes: analytics]
GA4_CREDENTIALS={"type":"service_account","project_id":"replace-me"}

# مهلة الجلسة بالدقائق للمسارات التي تحتاج إدارة جلسات. [scopes: builder]
SESSION_TIMEOUT_MINUTES=60

# الحد الأقصى لعمر الجلسة بالساعات في أدوات البناء. [scopes: builder]
SESSION_MAX_AGE_HOURS=24

# عدد عمال Uvicorn في وكيل البناء عند تشغيل واجهة HTTP. [scopes: builder]
WEB_CONCURRENCY=1

# رمز TikTok المستخدم في النشر التسويقي أو التجارب. [scopes: marketing]
TIKTOK_ACCESS_TOKEN=replace-me

# رمز Twitter Bearer للمسارات التي تعتمد واجهة X. [scopes: marketing]
TWITTER_BEARER_TOKEN=replace-me

# مفتاح Twitter API للنشر أو الجدولة. [scopes: marketing]
TWITTER_API_KEY=replace-me

# السرّ المقابل لمفتاح Twitter API. [scopes: marketing]
TWITTER_API_SECRET=replace-me
