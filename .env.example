# انسخ هذا الملف إلى .env وأضف القيم الحقيقية
# كل متغير موثّق بتعليق عربي موجز، وتُستخدم وسوم [scopes: ...] لدعم validate_env.py

# ================= Infrastructure =================

# اسم قاعدة بيانات PostgreSQL المشتركة بين خدمات المنظومة. [scopes: all]
POSTGRES_DB=ar_themes

# اسم مستخدم PostgreSQL الافتراضي داخل البيئة المحلية والحاويات. [scopes: all]
POSTGRES_USER=app_user

# كلمة مرور PostgreSQL الافتراضية ويجب استبدالها في البيئات الحقيقية. [scopes: all]
POSTGRES_PASSWORD=change_me

# مفتاح Anthropic المشترك للوكلاء التي تستخدم Claude. [scopes: supervisor,platform,support,content,marketing,analytics,visual]
ANTHROPIC_API_KEY=sk-ant-placeholder

# مفتاح LangSmith لتتبع التنفيذات والـ traces. [scopes: supervisor,content,marketing,analytics,support,visual]
LANGSMITH_API_KEY=lsv2_placeholder

# اسم مشروع LangSmith الموحد بين الوكلاء. [scopes: supervisor]
LANGSMITH_PROJECT=ar-themes-ecosystem

# مفتاح Resend لإرسال التنبيهات والبريد التشغيلي. [scopes: supervisor,platform,support,marketing,visual]
RESEND_API_KEY=re_placeholder

# بريد المالك الذي يستقبل التنبيهات والإشعارات التشغيلية. [scopes: supervisor,platform,support,marketing,visual]
OWNER_EMAIL=owner@example.com

# اسم البيئة الحالية مثل development أو staging. [scopes: supervisor,support,visual]
ENVIRONMENT=development

# تفعيل وضع التصحيح في البيئات المحلية فقط. [scopes: supervisor,support,visual]
DEBUG=false

# مستوى السجلات الافتراضي للخدمات. [scopes: all]
LOG_LEVEL=INFO

# رمز Telegram Bot للتنبيهات الإدارية أو النشر. [scopes: supervisor,marketing]
TELEGRAM_BOT_TOKEN=telegram-bot-placeholder

# معرّف محادثة Telegram الخاصة بالتنبيهات الإدارية. [scopes: supervisor]
TELEGRAM_CHAT_ID=000000000

# ================= Supervisor =================

# مهلة اعتبار الوكيل متوقف النبضات قبل التصعيد الصحي. [scopes: supervisor]
HEARTBEAT_TIMEOUT_SEC=120

# الفاصل الزمني بين دورات فحص الصحة داخل المشرف. [scopes: supervisor]
HEALTH_CHECK_INTERVAL_SEC=60

# ================= Platform =================

# مفتاح Lemon Squeezy لإدارة المنتجات والإصدارات. [scopes: platform]
LS_API_KEY=ls_api_placeholder

# معرّف متجر Lemon Squeezy. [scopes: platform]
LS_STORE_ID=store_placeholder

# السرّ المستخدم للتحقق من Webhooks Lemon Squeezy. [scopes: platform]
LS_WEBHOOK_SECRET=ls_webhook_placeholder

# معرّف منتج VIP الخاص بالمنصة. [scopes: platform]
LS_VIP_PRODUCT_ID=vip_product_placeholder

# رابط موقع WordPress الذي تنشر عليه المنصة. [scopes: platform]
WP_SITE_URL=https://nafic.example.com

# اسم مستخدم WordPress الخاص بالنشر البرمجي. [scopes: platform]
WP_API_USER=platform_agent

# كلمة مرور أو Application Password الخاصة بـ WordPress API. [scopes: platform]
WP_API_PASSWORD=wp_api_password_placeholder

# عنوان البريد الظاهر في الرسائل التجارية للمنصة. [scopes: platform]
STORE_EMAIL_FROM="Nafic <hello@example.com>"

# رابط المتجر المستخدم في الرسائل وروابط CTA. [scopes: platform]
STORE_URL=https://nafic.example.com

# اسم نموذج Claude المستخدم في وكيل المنصة. [scopes: platform]
CLAUDE_MODEL=claude-opus-4-6

# مهلة المراجعة البشرية بالساعات قبل التصعيد. [scopes: platform]
HUMAN_REVIEW_TIMEOUT_HOURS=48

# عدد الساعات الأولى لانتظار الأصول البصرية. [scopes: platform]
ASSET_INITIAL_WAIT_HOURS=4

# عدد الساعات الإضافية المسموح بها لانتظار الأصول. [scopes: platform]
ASSET_EXTENSION_HOURS=4

# الحد الأقصى لدورات التعديل أو المراجعة. [scopes: platform]
MAX_REVISION_CYCLES=3

# ================= Support =================

# مفتاح OpenAI المستخدم للـ embeddings في دعم العملاء. [scopes: support]
OPENAI_API_KEY=sk-openai-placeholder

# مفتاح HelpScout الرئيسي لقراءة وإدارة المحادثات. [scopes: support]
HELPSCOUT_API_KEY=helpscout_api_placeholder

# معرّف تطبيق HelpScout أو Integration App. [scopes: support]
HELPSCOUT_APP_ID=helpscout_app_placeholder

# معرّف صندوق البريد المستهدف في HelpScout. [scopes: support]
HELPSCOUT_MAILBOX_ID=helpscout_mailbox_placeholder

# رمز Meta المستخدم للردود على Facebook Messenger. [scopes: support]
META_ACCESS_TOKEN=meta_access_placeholder

# مزود الـ embeddings الخاص بوكيل الدعم. [scopes: support]
SUPPORT_EMBEDDING_PROVIDER=openai

# رابط واجهة embeddings المتوافقة مع OpenAI. [scopes: support]
SUPPORT_EMBEDDING_BASE_URL=https://api.openai.com/v1

# اسم نموذج embeddings لوكيل الدعم. [scopes: support]
SUPPORT_EMBEDDING_MODEL=text-embedding-3-small

# حجم المتجهات المخزنة في Qdrant لوكيل الدعم. [scopes: support]
SUPPORT_EMBEDDING_VECTOR_SIZE=1536

# ================= Content =================

# وكيل المحتوى يعتمد فقط على المتغيرات المشتركة من قسم Infrastructure. [scopes: content]

# ================= Marketing =================

# مفتاح MailerLite المستخدم للحملات البريدية. [scopes: marketing]
MAILERLITE_API_KEY=mailerlite_placeholder

# رمز Twitter Bearer للقراءة أو الجدولة عبر X API. [scopes: marketing]
TWITTER_BEARER_TOKEN=twitter_bearer_placeholder

# مفتاح Twitter API للنشر أو الجدولة. [scopes: marketing]
TWITTER_API_KEY=twitter_api_placeholder

# السرّ المقابل لمفتاح Twitter API. [scopes: marketing]
TWITTER_API_SECRET=twitter_secret_placeholder

# معرّف صفحة Meta أو Facebook للنشر التسويقي. [scopes: marketing]
META_PAGE_ID=meta_page_placeholder

# رمز صفحة Facebook الخاص بالنشر التسويقي. [scopes: marketing]
FACEBOOK_PAGE_TOKEN=facebook_page_placeholder

# رمز Instagram الخاص بالنشر عبر تكامل Meta. [scopes: marketing]
INSTAGRAM_ACCESS_TOKEN=instagram_access_placeholder

# رمز WhatsApp Business المستخدم للإرسال التسويقي. [scopes: marketing]
WHATSAPP_ACCESS_TOKEN=whatsapp_access_placeholder

# معرّف رقم WhatsApp Business المرتبط بالإرسال. [scopes: marketing]
WHATSAPP_PHONE_NUMBER_ID=whatsapp_phone_placeholder

# رمز TikTok المستخدم للنشر التسويقي. [scopes: marketing]
TIKTOK_ACCESS_TOKEN=tiktok_access_placeholder

# معرّف قناة Telegram المستخدمة للنشر التسويقي. [scopes: marketing]
TELEGRAM_CHANNEL_ID=@nafic_channel

# ================= Analytics =================

# معرّف خاصية GA4 التي يقرأ منها وكيل التحليل. [scopes: analytics]
GA4_PROPERTY_ID=123456789

# بيانات اعتماد GA4 بصيغة JSON أو path حسب أسلوب النشر. [scopes: analytics]
GA4_CREDENTIALS={"type":"service_account","project_id":"replace-me"}

# رابط WooCommerce الأساسي لقراءة المبيعات والطلبات. [scopes: analytics]
WOO_BASE_URL=https://store.example.com/wp-json/wc/v3

# مفتاح WooCommerce العام للقراءة من المتجر. [scopes: analytics]
WOO_CONSUMER_KEY=woo_ck_placeholder

# السرّ المقابل لمفتاح WooCommerce. [scopes: analytics]
WOO_CONSUMER_SECRET=woo_cs_placeholder

# ================= Visual Production =================

# مفتاح Flux لتوليد الصور أو اللقطات البصرية. [scopes: visual]
FLUX_API_KEY=flux_placeholder

# مفتاح Ideogram لتوليد العناصر البصرية النصية. [scopes: visual]
IDEOGRAM_API_KEY=ideogram_placeholder

# مفتاح Kling لتوليد الفيديو أو الحركة. [scopes: visual]
KLING_API_KEY=kling_placeholder

# مفتاح الوصول الإضافي لخدمة Kling عند الحاجة. [scopes: visual]
KLING_ACCESS_KEY=kling_access_placeholder

# مفتاح Pika لمسارات الفيديو القصير أو الحركة. [scopes: visual]
PIKA_API_KEY=pika_placeholder

# بريد مالك الإنتاج البصري للمراجعة والإشعارات. [scopes: visual]
VISUAL_OWNER_EMAIL=visual-owner@example.com

# مسار التخزين المحلي للأصول البصرية المولدة. [scopes: visual]
STORAGE_PATH=/app/storage

# الحد الأعلى لتكلفة الدفعة البصرية الواحدة. [scopes: visual]
VISUAL_BUDGET_LIMIT=2.00

# نطاقات CORS المسموح لها باستدعاء واجهات الإنتاج البصري. [scopes: visual]
CORS_ORIGINS=http://localhost:3000
